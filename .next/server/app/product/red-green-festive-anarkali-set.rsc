6:["$","$L12",null,{"children":["$","$L13",null,{"product":{"_id":"69a3564043e117e303520bb0","name":"Red & Green Festive Anarkali Set","slug":"red-green-festive-anarkali-set","description":"Celebrate in style with this stunning red Anarkali paired with a rich green Bandhani-inspired dupatta. The dress features delicate golden detailing on the neckline and pleated flare that adds graceful movement. The contrasting dupatta with intricate traditional patterns enhances its festive appeal.","category":"Anarkali","images":["https://res.cloudinary.com/douvhybil/image/upload/v1772312127/AWP%20Shopping-products/vhpilwtgvbdnz75gbxbm.jpg"],"price":800,"originalPrice":1067,"discountPercent":25,"sizes":["S","M","L","XL","XXL","3XL","4XL","5XL","6XL"],"colors":[{"name":"Red","hex":"#DC2626","_id":"a106c12e34b2794984140cbf"},{"name":"Green","hex":"#16A34A","_id":"1b9aa0581a0260e62aeecd83"}],"stock":33,"rating":4.8,"reviewCount":123,"isFeatured":true,"isNewArrival":false,"createdAt":"2026-02-28T20:55:28.107Z","__v":0},"related":[{"_id":"69b3f9bbf87a11ae382f5dd3","name":"Mauve Princess Charm Anarkali Frock","slug":"mauve-princess-charm-anarkali-frock","description":"Graceful mauve anarkali frock crafted with rich texture and royal simplicity. A perfect choice for traditional occasions and family gatherings.","category":"Anarkali","images":["https://res.cloudinary.com/douvhybil/image/upload/v1773402555/Ananyaa%20Boutique-products/efk3rsoi0fwcth0ipo5j.jpg"],"price":600,"originalPrice":750,"discountPercent":20,"sizes":["S","M","L","XL","XXL","3XL","4XL","5XL","6XL"],"colors":[{"name":"Any Colour","hex":"#808080","_id":"bab97c638afc9c5fbd33b688"}],"stock":32,"rating":5,"reviewCount":153,"isFeatured":true,"isNewArrival":false,"createdAt":"2026-03-13T11:49:15.425Z","__v":0},{"_id":"69b3f9c1f87a11ae382f5ddd","name":"Ivory Moonlight Classic Anarkali Suit","slug":"ivory-moonlight-classic-anarkali-suit","description":"Timeless white anarkali suit highlighted with subtle black detailing. Suita