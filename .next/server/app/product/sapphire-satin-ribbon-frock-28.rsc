6:["$","$L12",null,{"children":["$","$L13",null,{"product":{"_id":"69b5946e57d0a50d07d4532c","name":"Sapphire Satin-Ribbon Frock","slug":"sapphire-satin-ribbon-frock-28","description":"Beautiful floral frock designed for everyday elegance and special occasions. Lightweight, breathable fabric ensures all-day comfort while maintaining a stylish silhouette.","category":"Frock","images":["https://res.cloudinary.com/douvhybil/image/upload/v1773507694/annaya-boutique/frocks/yeexrlgl51awjmvajxwg.jpg"],"price":650,"originalPrice":850,"discountPercent":24,"sizes":["S","M","L","XL","XXL","3XL","4XL","5XL","6XL"],"colors":[{"name":"Multi","hex":"#FFFFFF","_id":"69b5946e57d0a50d07d4532d"}],"stock":40,"rating":4.8,"reviewCount":30,"isFeatured":false,"isNewArrival":false,"createdAt":"2026-03-14T17:01:34.159Z","__v":0},"related":[{"_id":"69b3f9c6f87a11ae382f5de5","name":"Zinnia Swiss-Dot Frock","slug":"zinnia-swiss-dot-frock-15","description":"Premium black party frock with subtle floral highlights creating a luxurious boutique appeal and modern charm.","category":"Frock","images":["https://res.cloudinary.com/douvhybil/image/upload/v1773402566/Ananyaa%20Boutique-products/ktxuiqdglctulfluyyjm.jpg"],"price":600,"originalPrice":750,"discountPercent":20,"sizes":["S","M","L","XL","XXL","3XL","4XL","5XL","6XL"],"colors":[{"name":"Any Colour","hex":"#808080","_id":"2d1ec326b29d3d0d3c22d38b"}],"stock":49,"rating":5,"reviewCount":155,"isFeatured":true,"isNewArrival":false,"createdAt":"2026-03-13T11:49:26.313Z","__v":0},{"_id":"69a35e8643e117e303520c39","name":"Red & Black Ombre Festive Gown","slug":"red-black-ombre-festive-gown","description":"Bold and elegant, this red-to-black ombre gown is designed to make a striking statement. Featuring a structured bodice with delicate embellishments and soft puff sleeves, the flowing pleated skirt adds dramatic movement and grace to every step.","category":"Frock","images":["https://res.cloudinary.com/douvhybil/image/upload/v1772314245/AWP%20Shopping-products/uwsey4hgzov8pdofqovc.jpg"],"price":500,"originalPrice":588,"discountPercent":15,"sizes":["S","M","L","XL","XXL","3XL","4XL","5XL","6XL"],"colors":[{"name":"Red","hex":"#DC2626","_id":"2d968895fc2ef03b4a6976ba"},{"name":"Black","hex":"#111827","_id":"14bf2cc1bf2c5977397ddc42"}],"stock":34,"rating":5,"reviewCount":1293,"isFeatured":false,"isNewArrival":false,"createdAt":"2026-02-28T21:30:46.491Z","__v":0},{"_id":"69b3f9c0f87a11ae382f5ddb","name":"Briar Polka-Dot Frock","slug":"briar-polka-dot-frock-14","description":"Classy turquoise designer frock with premium fall and minimal embellishment. Perfect for simple festive styling with a sophisticated touch.","category":"Frock","images":["https://res.cloudinary.com/douvhybil/image/upload/v1773402560/Ananyaa%20Boutique-products/nawkpogz0fh1ijy9bjpz.jpg"],"price":600,"originalPrice":750,"discountPercent":20,"sizes":["S","M","L","XL","XXL","3XL","4XL","5XL","6XL"],"colors":[{"name":"Any Colour","hex":"#808080","_id":"b2c1a4060bdfbfbb34e5ba6d"}],"stock":27,"rating":5,"reviewCount":146,"isFeatured":true,"isNewArrival":false,"createdAt":"2026-03-13T11:49:20.586Z","__v":0},{"_id":"69a35c5a43e117e303520c1e","name":"Sunshine Yellow & Teal Ombre Gown","slug":"sunshine-yellow-teal-ombre-gown","description":"Bright, cheerful, and effortlessly graceful, this sunshine yellow gown transitions beautifully into a deep teal ombre hem. The embellished bodice paired with soft pleats creates a refreshing festive look perfect for daytime celebrations.","category":"Frock","images":["https://res.cloudinary.com/douvhybil/image/upload/v1772313689/AWP%20Shopping-products/gwgpp5mk9y5pfh174app.jpg"],"price":500,"originalPrice":588,"discountPercent":15,"sizes":["S","M","L","XL","XXL","3XL","4XL","5XL","6XL"],"colors":[{"name":"Yellow","hex":"#F5C518","_id":"ff4ae12a01b4612c40bae4e7"}],"stock":22,"rating":5,"reviewCount":1347,"isFeatured":false,"isNewArrival":false,"createdAt":"2026-02-28T21:21:30.297Z","__v":0}]}]}]
