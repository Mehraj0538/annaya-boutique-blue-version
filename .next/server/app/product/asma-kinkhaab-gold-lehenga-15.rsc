6:["$","$L12",null,{"children":["$","$L13",null,{"product":{"_id":"69b59262e16b49614339aba4","name":"Asma Kinkhaab Gold Lehenga","slug":"asma-kinkhaab-gold-lehenga-15","description":"Stunning designer lehenga perfect for weddings and festive occasions. Features intricate detailing and comes with a matching blouse and dupatta. Crafted with premium materials for maximum comfort and style.","category":"Lehenga","images":["https://res.cloudinary.com/douvhybil/image/upload/v1773507171/annaya-boutique/lehengas/dacvxdjekyhgwzdyahxh.jpg"],"price":1050,"originalPrice":1300,"discountPercent":19,"sizes":["S","M","L","XL","XXL","3XL","4XL","5XL","6XL"],"colors":[{"name":"Default","hex":"#CCCCCC","_id":"69b59262e16b49614339aba5"}],"stock":12,"rating":4.313251551891,"reviewCount":60,"isFeatured":false,"isNewArrival":false,"createdAt":"2026-03-14T16:52:50.836Z","__v":0},"related":[{"_id":"69b5925fe16b49614339aba1","name":"Mehrunnisa Hand-Painted Lehenga","slug":"mehrunnisa-hand-painted-lehenga-14","description":"Stunning designer lehenga perfect for weddings and festive occasions. Features intricate detailing and comes with a matching blouse and dupatta. Crafted with premium materials for maximum comfort and style.","category":"Lehenga","images":["https://res.cloudinary.com/douvhybil/image/upload/v1773507168/annaya-boutique/lehengas/q2zfkcle4b4n0oj1wbxh.jpg"],"price":1000,"originalPrice":1250,"discountPercent":20,"sizes":["S","M","L","XL","XXL","3XL","4XL","5XL","6XL"],"colors":[{"name":"Default","hex":"#CCCCCC","_id":"69b5925fe16b49614339aba2"}],"stock":33,"rating":4.976273748714329,"reviewCount":24,"isFeatured":true,"isNewArrival":false,"createdAt":"2026-03-14T16:52:47.452Z","__v":0},{"_id":"69b5926de16b49614339abad","name":"Laila Resham-Embroidered Lehenga","slug":"laila-resham-embroidered-lehenga-18","description":"Stunning designer lehenga perfect for weddings and festive occasions. Features intricate detailing and comes with a matching blouse and dupatta. Crafted with premium materials for maximum comfort and style.","category":"Lehenga","images":["https://res.cloudinary.com/douvhybil/image/upload/v1773507182/annaya-boutique/lehengas/jbaxwovn64dp4m7jjzcq.jpg"],"price":1200,"originalPrice":1450,"discountPercent":17,"sizes":["S","M","L","XL","XXL","3XL","4XL","5XL","6XL"],"colors":[{"name":"Default","hex":"#CCCCCC","_id":"69b5926de16b49614339abae"}],"stock":13,"rating":4.920951576130149,"reviewCount":84,"isFeatured":false,"isNewArrival":false,"createdAt":"2026-03-14T16:53:01.612Z","__v":0},{"_id":"69a35b3643e117e303520c12","name":"Nusrat Cut-Dana Festive Lehenga","slug":"nusrat-cut-dana-festive-lehenga-5","description":"Rich and dramatic, this deep wine lehenga features intricate wildlife prints along the hemline. Paired with a matching printed jacket, this set offers regal sophistication with a modern ethnic twist.","category":"Lehenga","images":["https://res.cloudinary.com/douvhybil/image/upload/v1772313398/AWP%20Shopping-products/idetiiy4aylai1gqu7a7.jpg"],"price":1350,"originalPrice":1929,"discountPercent":30,"sizes":["S","M","L","XL","XXL","3XL","4XL","5XL","6XL"],"colors":[{"name":"Wine","hex":"#7F1D1D","_id":"1706ec120270eacb5287fe47"}],"stock":8,"rating":4.9,"reviewCount":132,"isFeatured":true,"isNewArrival":false,"createdAt":"2026-02-28T21:16:38.890Z","__v":0},{"_id":"69a35a8543e117e303520c02","name":"Maharani Bridal Embroidered Lehenga","slug":"maharani-bridal-embroidered-lehenga-1","description":"A vibrant celebration of art and culture, this mustard yellow lehenga features playful jungle-inspired prints with elephants, giraffes, and wildlife motifs. Paired with a contrasting aqua dupatta detailed with intricate animal borders, this ensemble creates a bold yet graceful festive look.","category":"Lehenga","images":["https://res.cloudinary.com/douvhybil/image/upload/v1772313220/AWP%20Shopping-products/slnca7eupimksb6fc4z2.jpg"],"price":1350,"originalPrice":1929,"discountPercent":30,"sizes":["S","M","L","XL","XXL","3XL","4XL","5XL","6XL"],"colors":[{"name":"Yellow","hex":"#F5C518","_id":"a0e67afc65b98a8473cfdfc8"}],"stock":16,"rating":4.8,"reviewCount":119,"isFeatured":true,"isNewArrival":false,"createdAt":"2026-02-28T21:13:41.524Z","__v":0}]}]}]
