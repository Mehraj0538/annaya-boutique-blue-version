[{"_id":"69a3555c43e117e303520ba0","name":"Elara Chiffon Tiered Frock","slug":"elara-chiffon-tiered-frock-2","description":"A dreamy blend of elegance and comfort, this lavender floral midi dress adds a soft romantic touch to your everyday style. Designed with a flattering empire waist and airy silhouette, it creates a graceful flow while ensuring all-day comfort.","category":"Frock","images":["https://res.cloudinary.com/douvhybil/image/upload/v1772311899/AWP%20Shopping-products/btaidpqmkpr3vcdsadna.jpg"],"price":750,"originalPrice":1000,"discountPercent":25,"sizes":["S","M","L","XL","XXL","3XL","4XL","5XL","6XL"],"colors":[{"name":"Lavender","hex":"#C4B5FD","_id":"c2310777ea3631058093923e"}],"stock":15,"rating":4.6,"reviewCount":88,"isFeatured":true,"isNewArrival":false,"createdAt":"2026-02-28T20:51:40.558Z","__v":0},{"_id":"69a355a443e117e303520ba8","name":"Navy Blue Embroidered Anarkali Dress","slug":"navy-blue-embroidered-anarkali-dress","description":"Step into timeless elegance with this navy blue embroidered Anarkali dress. Featuring intricate golden embroidery on the bodice and a beautifully pleated skirt, this outfit blends traditional craftsmanship with modern sophistication. Paired with a matching dupatta, it creates a regal festive look.","category":"Anarkali","images":["https://res.cloudinary.com/douvhybil/image/upload/v1772311971/AWP%20Shopping-products/ckh1vm8rl4er6xnrwwhu.jpg"],"price":750,"originalPrice":1000,"discountPercent":25,"sizes":["S","M","L","XL","XXL","3XL","4XL","5XL","6XL"],"colors":[{"name":"Navy","hex":"#1E3A8A","_id":"3e9d86ac6fd9d67e450ca674"},{"name":"Blue","hex":"#3B82F6","_id":"1edfbe44d5dc2b55a24acd27"}],"stock":19,"rating":4.9,"reviewCount":128,"isFeatured":true,"isNewArrival":false,"createdAt":"2026-02-28T20:52:52.402Z","__v":0},{"_id":"69a3564043e117e303520bb0","name":"Red & Green Festive Anarkali Set","slug":"red-green-festive-anarkali-set","description":"Celebrate in style with this stunning red Anarkali paired with a rich green Bandhani-inspired dupatta. The dress features delicate golden detailing on the neckline and pleated flare that adds graceful movement. The contrasting dupatta with intricate traditional patterns enhances its festive appeal.","category":"Anarkali","images":["https://res.cloudinary.com/douvhybil/image/upload/v1772312127/AWP%20Shopping-products/vhpilwtgvbdnz75gbxbm.jpg"],"price":800,"originalPrice":1067,"discountPercent":25,"sizes":["S","M","L","XL","XXL","3XL","4XL","5XL","6XL"],"colors":[{"name":"Red","hex":"#DC2626","_id":"a106c12e34b2794984140cbf"},{"name":"Green","hex":"#16A34A","_id":"1b9aa0581a0260e62aeecd83"}],"stock":33,"rating":4.8,"reviewCount":123,"isFeatured":true,"isNewArrival":false,"createdAt":"2026-02-28T20:55:28.107Z","__v":0},{"_id":"69a356e143e117e303520bc0","name":"Emerald Green & Maroon Festive Anarkali","slug":"emerald-green-maroon-festive-anarkali","description":"A royal blend of emerald green Anarkali paired with a maroon printed dupatta. The gold neckline detailing and pleated silhouette give this outfit a timeless ethnic elegance. A perfect balance of tradition and sophistication.","category":"Anarkali","images":["https://res.cloudinary.com/douvhybil/image/upload/v1772312288/AWP%20Shopping-products/rfhz4c3mia7odrde8xlc.jpg"],"price":800,"originalPrice":1067,"discountPercent":25,"sizes":["S","M","L","XL","XXL","3XL","4XL","5XL","6XL"],"colors":[{"name":"Green","hex":"#16A34A","_id":"8ac229c801879b0319470fd9"}],"stock":32,"rating":4.7,"reviewCount":99,"isFeatured":true,"isNewArrival":false,"createdAt":"2026-02-28T20:58:09.249Z","__v":0},{"_id":"69a358b543e117e303520bea","name":"Willow Boho Maxi Frock","slug":"willow-boho-maxi-frock-8","description":"Romantic and graceful, this lavender butterfly maxi dress radiates soft elegance. The delicate purple butterfly prints paired with a voluminous pleated skirt create a dreamy silhouette that flows beautifully with movement.","category":"Frock","images":["https://res.cloudinary.com/douvhybil/imag